// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// インスタンス（Mastodon/Misskeyサーバー）
// 動的クライアント登録のため、client_id/secretはDBに保存しない
model Instance {
  id        String   @id @default(uuid())
  domain    String   @unique @db.VarChar(511)
  type      String   @db.VarChar(20) // "mastodon" | "misskey"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("instances")
}

// ユーザー
model User {
  id           String    @id @default(uuid())
  instanceId   String    @map("instance_id")
  remoteId     String    @map("remote_id") @db.VarChar(255)
  username     String    @db.VarChar(255)
  displayName  String?   @map("display_name") @db.VarChar(255)
  avatarUrl    String?   @map("avatar_url") @db.Text
  emailPrefix  String    @unique @map("email_prefix") @db.VarChar(32)
  accessToken  String    @map("access_token") @db.Text
  refreshToken String?   @map("refresh_token") @db.Text
  bio          String?   @db.VarChar(40)

  // 投稿のデフォルト設定
  defaultPosition    String?   @map("default_position") @db.VarChar(20)
  defaultFont        String?   @map("default_font") @db.VarChar(50)
  defaultColor       String?   @map("default_color") @db.VarChar(20)
  defaultSize        String?   @map("default_size") @db.VarChar(20)
  defaultOutput      String?   @map("default_output") @db.VarChar(20)
  defaultArrangement String?   @map("default_arrangement") @db.VarChar(20)
  defaultVisibility  String?   @map("default_visibility") @db.VarChar(20)
  // 投稿時の追加情報のデフォルト: カメラ機種名の表示 ("none" | "show")
  defaultCameraOption String?  @map("default_camera_option") @db.VarChar(20)
  mentionKeep        Boolean   @default(false) @map("mention_keep")
  // 地図機能（ベータ）の公開オプトイン。デフォルトoff、自分の画像投稿の都道府県集計を地図で公開する
  showLocationMap    Boolean   @default(false) @map("show_location_map")
  // 検索エンジン/AI Botのクロール拒否オプトイン。デフォルトoff（=従来どおり許可）。
  // ON → /u/[username] 配下を検索エンジンに noindex（generateMetadata）し、AI BotをrobotsでDisallow。
  blockCrawlers      Boolean   @default(false) @map("block_crawlers")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  instance      Instance       @relation(fields: [instanceId], references: [id])
  images        Image[]
  loginSessions LoginSession[]
  achievements  Achievement[]
  notifications Notification[]
  reports       Report[]

  @@unique([instanceId, remoteId])
  @@unique([instanceId, username])
  @@map("users")
}

// 実績（トロフィー）。獲得は永続（要件を満たさなくなっても剥奪しない）。
model Achievement {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  // 安定キー。固定実績は "posts:50" など、動的実績は "perfect-month:2026-06"。
  key       String   @db.VarChar(64)
  // カタログ系列キー（タブ表示・グルーピング用）。例: "post-count" / "perfect-month"
  category  String   @db.VarChar(40)
  // この実績を獲得したきっかけの投稿（閾値を超えた1枚）。画像削除時は null。
  imageId   String?  @map("image_id")
  grantedAt DateTime @default(now()) @map("granted_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  image Image? @relation(fields: [imageId], references: [id], onDelete: SetNull)

  @@unique([userId, key]) // レース時の二重付与をDBで防ぐ
  @@index([userId, grantedAt])
  @@map("achievements")
}

// 通知。ユーザーごとに生成され、種別（type）で情報ソースを区別する。
// 現状は実績獲得("achievement")のみだが、将来「お気に入りされた通知」など別種別をここにマージする。
// 90日で読み捨て（読み取り時に createdAt でフィルタ）。既読状態は持たない。
model Notification {
  id   String @id @default(uuid())
  // 通知の受信者
  userId String @map("user_id")
  // 種別 / 情報ソース。"achievement" | （将来）"favorite" 等
  type String @db.VarChar(40)
  // type="achievement" のとき、獲得した実績のキー（表示文言は CATALOG から解決）
  achievementKey String? @map("achievement_key") @db.VarChar(64)
  // 関連画像（実績のきっかけ写真 / 将来: お気に入りされた写真）。画像削除時は null。
  imageId String? @map("image_id")
  // 種別ごとの追加情報（将来用: お気に入りした相手の表示名・acct 等）
  data Json?
  createdAt DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  image Image? @relation(fields: [imageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("notifications")
}

// ログイン履歴（セッション単位の記録、本人の自己検出用）
// プライバシーポリシーに従い、作成から90日経過した行はログイン時に自動削除
model LoginSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  jti       String   @unique
  ipAddress String   @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(500)
  country   String?  @db.VarChar(2)
  // Cloudflareの「Add visitor location headers」によるIP推定の地域。精度は低くズレる前提
  region    String?  @db.VarChar(100)
  city      String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  // 失効日時。nullなら有効。本人がセッションを失効させると設定される
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("login_sessions")
}

// 画像
model Image {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  storageKey    String   @unique @map("storage_key") @db.VarChar(500)
  filename      String   @db.VarChar(255)
  mimeType      String   @map("mime_type") @db.VarChar(100)
  fileSize      Int      @map("file_size")
  width         Int
  height        Int
  overlayText   String   @map("overlay_text") @db.Text
  position      String   @db.VarChar(20)
  font          String   @db.VarChar(50)
  color         String   @db.VarChar(20)
  size          String   @db.VarChar(20)
  outputFormat  String   @map("output_format") @db.VarChar(20)
  arrangement   String   @default("none") @db.VarChar(20)
  source        String   @default("web") @db.VarChar(20) // "web" | "email"
  thumbnailKey  String?  @map("thumbnail_key") @db.VarChar(500)
  postUrl       String?  @map("post_url") @db.Text
  postId        String?  @map("post_id") @db.VarChar(255)
  isPublic      Boolean  @default(true) @map("is_public")
  // Mastodonのお気に入りキャッシュ（Mastodonが正データ）
  favoriteCount     Int       @default(0) @map("favorite_count")
  favoritersCache   Json?     @map("favoriters_cache")
  favoritesSyncedAt DateTime? @map("favorites_synced_at")
  postStatus        Int?      @map("post_status") // 最後のMastodon sync HTTP status（0=接続失敗、200=OK、4xx=失敗、5xx=サーバ不調）
  pinnedAt      DateTime? @map("pinned_at")
  // 管理者によるモデレーション取り下げフラグ。true で全公開面から隠す（投稿者含め非表示・復元可能）
  isDisabled    Boolean   @default(false) @map("is_disabled")
  // EXIFメタデータ（出力画像からは常に除去、ここはDB保存のみ／位置情報は投稿時オプトイン）
  cameraMake         String?   @map("camera_make") @db.VarChar(100)
  cameraModel        String?   @map("camera_model") @db.VarChar(100)
  capturedAt         DateTime? @map("captured_at")
  locationPrefecture String?   @map("location_prefecture") @db.VarChar(50)
  locationCity       String?   @map("location_city") @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievements  Achievement[]
  notifications Notification[]
  reports       Report[]

  @@index([userId, createdAt])
  @@index([isPublic, createdAt])
  @@map("images")
}

// 通報。ログインユーザーが画像を通報した記録。
// 通報直後は何もせず、管理者が /admin/reports で対応したときに status が変わる。
model Report {
  id         String    @id @default(uuid())
  imageId    String    @map("image_id")
  reporterId String    @map("reporter_id")
  reason     String    @db.VarChar(100)
  status     String    @default("open") @db.VarChar(20) // "open" | "resolved" | "dismissed"
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  image    Image @relation(fields: [imageId], references: [id], onDelete: Cascade)
  reporter User  @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([imageId, reporterId]) // 同一ユーザーの同一画像への重複通報を防ぐ
  @@index([status, createdAt]) // 未対応一覧の取得用
  @@map("reports")
}

// Bot状態管理（シングルトン）
model BotState {
  id                 String   @id @default("singleton")
  lastNotificationId String?  @map("last_notification_id")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("bot_state")
}

// 処理済みメンション
model ProcessedMention {
  statusId   String        @id @map("status_id")
  status     MentionStatus @default(pending)
  retryCount Int           @default(0) @map("retry_count")
  errorCode  String?       @map("error_code") @db.VarChar(100)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("processed_mentions")
}

enum MentionStatus {
  pending
  success
  failed
}
